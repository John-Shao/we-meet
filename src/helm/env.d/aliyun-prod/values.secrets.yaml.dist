# Production secrets for the Aliyun deployment.
#
# USAGE:
#   1. cp values.secrets.yaml.dist values.secrets.yaml
#   2. Fill in every REPLACE_* placeholder below.
#   3. Never commit values.secrets.yaml — it is gitignored via the rule
#      added in src/helm/env.d/aliyun-prod/.gitignore
#
# Generate strong secrets:
#   openssl rand -hex 32       # for DJANGO_SECRET_KEY, LIVEKIT_API_SECRET, etc.
#   openssl rand -base64 32    # for passwords

backend:
  envVars:
    DJANGO_SECRET_KEY: REPLACE_DJANGO_SECRET_KEY
    DJANGO_SUPERUSER_EMAIL: admin@example.com
    DJANGO_SUPERUSER_PASSWORD: REPLACE_ADMIN_PASSWORD

    DB_PASSWORD: REPLACE_POSTGRES_APP_PASSWORD
    REDIS_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/1
    DJANGO_CELERY_BROKER_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/0

    OIDC_RP_CLIENT_ID: meet
    OIDC_RP_CLIENT_SECRET: REPLACE_KEYCLOAK_CLIENT_SECRET

    LIVEKIT_API_SECRET: REPLACE_LIVEKIT_API_SECRET

    AWS_S3_ACCESS_KEY_ID: REPLACE_OSS_ACCESS_KEY_ID
    AWS_S3_SECRET_ACCESS_KEY: REPLACE_OSS_ACCESS_KEY_SECRET

    SUMMARY_SERVICE_API_TOKEN: REPLACE_SUMMARY_API_TOKEN

    DJANGO_EMAIL_HOST_USER: REPLACE_SMTP_USER
    DJANGO_EMAIL_HOST_PASSWORD: REPLACE_SMTP_PASSWORD

celery:
  envVars:
    DJANGO_SECRET_KEY: REPLACE_DJANGO_SECRET_KEY
    DB_PASSWORD: REPLACE_POSTGRES_APP_PASSWORD
    REDIS_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/1
    DJANGO_CELERY_BROKER_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/0
    AWS_S3_ACCESS_KEY_ID: REPLACE_OSS_ACCESS_KEY_ID
    AWS_S3_SECRET_ACCESS_KEY: REPLACE_OSS_ACCESS_KEY_SECRET
    LIVEKIT_API_SECRET: REPLACE_LIVEKIT_API_SECRET

summary: &summarySecretEnvVars
  envVars:
    APP_API_TOKEN: REPLACE_SUMMARY_API_TOKEN
    WEBHOOK_API_TOKEN: REPLACE_SUMMARY_WEBHOOK_TOKEN

    AWS_S3_ACCESS_KEY_ID: REPLACE_OSS_ACCESS_KEY_ID
    AWS_S3_SECRET_ACCESS_KEY: REPLACE_OSS_ACCESS_KEY_SECRET

    LLM_API_KEY: REPLACE_VOLCENGINE_ARK_API_KEY
    WHISPERX_API_KEY: REPLACE_VOLCENGINE_ARK_API_KEY

    CELERY_BROKER_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/2
    CELERY_RESULT_BACKEND: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/2
    TASK_TRACKER_REDIS_URL: redis://default:REPLACE_REDIS_PASSWORD@redis-master:6379/3

celeryTranscribe: *summarySecretEnvVars
celerySummarize:  *summarySecretEnvVars
celerySummaryBackend: *summarySecretEnvVars

agentMetadata:
  envVars:
    LIVEKIT_API_SECRET: REPLACE_LIVEKIT_API_SECRET
    AWS_S3_ACCESS_KEY_ID: REPLACE_OSS_ACCESS_KEY_ID
    AWS_S3_SECRET_ACCESS_KEY: REPLACE_OSS_ACCESS_KEY_SECRET

# LiveKit chart - keys block
livekit:
  keys:
    meet: REPLACE_LIVEKIT_API_SECRET
  redis:
    password: REPLACE_REDIS_PASSWORD
  webhook:
    # NOTE: webhook.api_key 是 keys: 块里的 KEY 名字 (用来签 outgoing webhook),
    # 不是一个独立的 secret 值. 当前只有一个 key "meet" 所以填 "meet".
    # LiveKit 用 keys.meet 对应的 secret (== LIVEKIT_API_SECRET) 签 webhook payload,
    # backend 用同一个 secret 验签.
    api_key: meet

# Image pull credentials for 火山引擎 CR
# 注意: 主账号 AK/SK 不能 docker login 火山 CR. 必须在 CR 控制台 → 实例 → 访问凭证
# 创建一个用户名 + 固定密码. username 格式 <custom_user>@<account_id>.
image:
  credentials:
    username: REPLACE_VOLC_CR_USERNAME    # 例如 MYORG2025@2114082505
    password: REPLACE_VOLC_CR_PASSWORD    # 该用户名对应的固定密码
    registry: your-cr.cr.volces.com
    name: meet-dockerconfig
